<%- layout("layouts/navbar") %>

<div class="min-h-screen bg-gray-900 flex flex-col items-center justify-center px-4 py-6 space-y-5">

  <!-- CALL HEADER -->
  <div class="text-white text-center">
    <h2 class="text-2xl font-bold">📞 Video Call</h2>
    <p class="text-sm text-gray-300 mt-1">Connected securely via Shaadiwali</p>
  </div>



  <!-- VIDEO CONTAINER -->
  <div class="relative w-full max-w-5xl aspect-video bg-black rounded-xl overflow-hidden shadow-lg">

    <!-- REMOTE VIDEO -->
    <video
      id="remoteVideo"
      autoplay
      playsinline
      class="w-full h-full object-cover"
    ></video>

    <!-- LOCAL VIDEO -->
    <video
      id="localVideo"
      autoplay
      muted
      playsinline
      class="absolute bottom-4 right-4 w-40 h-28 object-cover rounded-lg border-2 border-white shadow-lg"
    ></video>

  </div>
  <div id="extendModal" class="hidden fixed inset-0 bg-black bg-opacity-60 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-80 text-center shadow-lg">
      <h3 class="text-lg font-bold mb-2">⏱ Extend Call</h3>
      <p class="text-gray-600 mb-4">Choose how long to continue</p>
      <div class="flex flex-col gap-2">
        <button onclick="extendCall(10)" class="bg-blue-600 text-white py-2 rounded">+10 min</button>
        <button onclick="extendCall(20)" class="bg-blue-600 text-white py-2 rounded">+20 min</button>
        <button onclick="extendCall(30)" class="bg-blue-600 text-white py-2 rounded">+30 min</button>
      </div>
    </div>
  </div>
  

  <!-- CONTROLS -->
  <div class="flex items-center gap-6 mt-4">

    <button
      onclick="toggleMute()"
      id="muteBtn"
      class="bg-gray-700 text-white px-4 py-2 rounded-full hover:bg-gray-600 transition"
    >
      🔇 Mute
    </button>

    <button
      onclick="endCall()"
      class="bg-red-600 text-white px-6 py-3 rounded-full font-semibold hover:bg-red-700 transition shadow-lg"
    >
      ❌ End Call
    </button>

    <button
      onclick="toggleCamera()"
      id="cameraBtn"
      class="bg-gray-700 text-white px-4 py-2 rounded-full hover:bg-gray-600 transition"
    >
      📷 Camera Off
    </button>

  </div>

</div>




   <script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
socket.on("end_call", () => {
  alert("📞 Call ended by other user");
  endCall();
});

const roomId = "<%= receiver.phone %>";
let localStream;
let peerConnection;
let callEnded = false;
let autoEndTimer;

const iceServers = {
  iceServers: [{ urls: "stun:stun.l.google.com:19302" }]
};

async function startCall() {
  const res = await fetch("/api/call/start", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      roomId: roomId,
      withPhone: "<%= receiver.phone %>"
    })
  });

  const result = await res.json();
  if (!result.success) {
    if (result.error === "Already in another call") {
  alert("⚠ You already have an active call. Please refresh or end it.");
  window.location.href = "/profile";
} else {
  alert(result.error || "Unable to start call");
  window.location.href = "/tokens";
}

    return;
  }

  // Show extend modal after FIRST 5 PAID minutes
  autoEndTimer = setTimeout(() => {
    document.getElementById("extendModal").classList.remove("hidden");

    // Auto end call if no extension after 1 minute
    setTimeout(() => {
      if (!callEnded) {
        alert("⛔ Call ended (not extended)");
        endCall();
      }
    }, 60 * 1000);

  }, 5 * 60 * 1000);

  localStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
  document.getElementById("localVideo").srcObject = localStream;

  peerConnection = new RTCPeerConnection(iceServers);
  localStream.getTracks().forEach(track => peerConnection.addTrack(track, localStream));

  peerConnection.ontrack = e => {
    document.getElementById("remoteVideo").srcObject = e.streams[0];
  };

  peerConnection.onicecandidate = e => {
    if (e.candidate) socket.emit("ice_candidate", { roomId, candidate: e.candidate });
  };

  socket.emit("join_call", { roomId });

  const offer = await peerConnection.createOffer();
  await peerConnection.setLocalDescription(offer);
  socket.emit("offer", { roomId, offer });
}

function endCall() {
  if (callEnded) return;
  callEnded = true;

  clearTimeout(autoEndTimer);

  fetch("/api/call/end", { method: "POST" });
  socket.emit("end_call", { roomId });

  if (peerConnection) {
    peerConnection.close();
    peerConnection = null;
  }

  if (localStream) {
    localStream.getTracks().forEach(track => track.stop());
  }

  setTimeout(() => {
    window.location.href = document.referrer || "/profile";
  }, 500);
}

async function extendCall(minutes) {
  const res = await fetch("/api/call/extend", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ minutes })
  });

  const data = await res.json();
  if (!data.success) {
    alert(data.error || "Failed to extend call");
    return;
  }

  document.getElementById("extendModal").classList.add("hidden");
  alert(`✅ Call extended by ${minutes} minutes`);
}

// UI toggles
let isMuted = false;
let isCameraOff = false;

function toggleMute() {
  if (!localStream) return;
  localStream.getAudioTracks().forEach(track => {
    track.enabled = isMuted;
  });
  isMuted = !isMuted;
  document.getElementById("muteBtn").innerText = isMuted ? "🔊 Unmute" : "🔇 Mute";
}

function toggleCamera() {
  if (!localStream) return;
  localStream.getVideoTracks().forEach(track => {
    track.enabled = isCameraOff;
  });
  isCameraOff = !isCameraOff;
  document.getElementById("cameraBtn").innerText = isCameraOff ? "📷 Camera On" : "📷 Camera Off";
}

startCall();
</script>
