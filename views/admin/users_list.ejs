<%- layout("layouts/navbar.ejs") %>

<div class="max-w-6xl mx-auto mt-10 bg-white shadow-xl rounded-2xl p-6 border border-gray-200">

  <h2 class="text-2xl font-bold text-gray-800 mb-6 flex items-center gap-2">
    👥 Admin Added Users
  </h2>

  <div class="overflow-x-auto rounded-lg border border-gray-200">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      
      <!-- TABLE HEADER -->
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left font-semibold text-gray-700 uppercase tracking-wider">
            Name
          </th>
          <th class="px-6 py-3 text-left font-semibold text-gray-700 uppercase tracking-wider">
            Phone
          </th>
          <th class="px-6 py-3 text-left font-semibold text-gray-700 uppercase tracking-wider">
            Added By
          </th>
        </tr>
      </thead>

      <!-- TABLE BODY -->
      <tbody class="divide-y divide-gray-100 bg-white">
        <% users.forEach(u => { %>
          <tr class="hover:bg-blue-50 transition">

            <td class="px-6 py-4 font-medium text-gray-800">
              <%= u.first_name %> <%= u.last_name %>
            </td>

            <td class="px-6 py-4 text-gray-600">
              <%= u.phone || "N/A" %>
            </td>

            <td class="px-6 py-4 text-gray-600">
              <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-indigo-100 text-indigo-700">
                <%= u.createdByAdmin?.phone || "Admin" %>
              </span>
            </td>

          </tr>
        <% }) %>
      </tbody>

    </table>
  </div>

  <% if (!users || users.length === 0) { %>
    <div class="text-center text-gray-500 py-6">
      No users found.
    </div>
  <% } %>

</div>
